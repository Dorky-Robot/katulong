# UI server port (default: 3001)
PORT=3001
# Log verbosity: debug, info, warn, error (default: info)
LOG_LEVEL=info
# Directory for persistent state files (default: ~/.katulong)
KATULONG_DATA_DIR=
# SSH server port (default: 2222)
SSH_PORT=2222
# SSH password (auto-generated if not set)
SSH_PASSWORD=
