{
  "name": "katulong",
  "version": "0.14.8",
  "private": true,
  "type": "module",
  "bin": {
    "katulong": "./bin/katulong"
  },
  "scripts": {
    "postinstall": "true",
    "start": "node server.js",
    "start:dev": "nodemon server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-test-module-mocks --test test/*.test.js test/*.integration.js",
    "test:all": "npm test && npm run test:e2e",
    "test:unit": "node --experimental-test-module-mocks --test test/*.test.js",
    "test:integration": "node --test test/*.integration.js",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test test/e2e/smoke.e2e.js --project=desktop",
    "test:e2e:sharded": "bash scripts/run-e2e-sharded.sh",
    "test:e2e:clean": "bash test/e2e/cleanup-test-server.sh",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.0.0",
    "dotenv": "^17.2.4",
    "node-datachannel": "^0.12.0",
    "simple-peer": "^9.11.1",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11"
  }
}
