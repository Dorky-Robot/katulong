{
  "name": "katulong",
  "version": "0.58.7",
  "description": "Self-hosted web terminal for remote machines. Browser-based shell access with tmux sessions, file browser, and WebAuthn security.",
  "keywords": [
    "web-terminal",
    "self-hosted",
    "remote-access",
    "browser-terminal",
    "tmux",
    "xterm",
    "websocket",
    "ssh-alternative",
    "homelab",
    "ipad-terminal"
  ],
  "private": true,
  "type": "module",
  "katulong": {
    "plugins": []
  },
  "bin": {
    "katulong": "./bin/katulong"
  },
  "scripts": {
    "postinstall": "true",
    "start": "node server.js",
    "start:dev": "nodemon server.js",
    "dev": "nodemon server.js",
    "test": "node --import ./test/helpers/setup-env.js --experimental-test-module-mocks --test test/*.test.js test/*.integration.js",
    "test:all": "npm test && npm run test:e2e",
    "test:unit": "node --import ./test/helpers/setup-env.js --experimental-test-module-mocks --test test/*.test.js",
    "test:integration": "node --import ./test/helpers/setup-env.js --test test/*.integration.js",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "npx playwright test test/e2e/smoke.e2e.js --project=desktop",
    "test:e2e:sharded": "bash scripts/run-e2e-sharded.sh",
    "test:e2e:clean": "bash test/e2e/cleanup-test-server.sh",
    "test:garble": "node --test test/harness/garble-detection.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.0.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "dotenv": "^17.2.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.2"
  },
  "optionalDependencies": {
    "node-datachannel": "^0.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11"
  }
}
