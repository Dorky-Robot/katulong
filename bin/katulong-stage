#!/usr/bin/env bash
#
# katulong-stage — stage an isolated Katulong instance behind a Cloudflare tunnel
#
# Usage:
#   katulong-stage start [name]    Start staging (default name = current branch)
#   katulong-stage stop  [name]    Tear down a staging instance (default = all)
#   katulong-stage list            Show running staging instances
#
# What "isolated" means:
#   - Unique data dir at /tmp/katulong-stage/<name>/data
#       (passkeys, sessions, tokens never collide with the prod katulong)
#   - Unique tmux socket via KATULONG_TMUX_SOCKET=stage-<name>
#       (tearing down staging never touches prod tmux)
#   - Free port allocated dynamically (starting at 3050)
#   - Setup token minted via the proper `katulong token create` CLI
#       (no hand-crafted auth state)
#   - Stable public hostname <name>.<tunnel> via the existing named
#       cloudflared tunnel, managed exclusively by the `tunnels` CLI.
#
# Tunnels CLI is REQUIRED. There is no fallback path. The original version
# of this script had an "ephemeral trycloudflare URL via raw cloudflared"
# fallback for boxes without `tunnels` installed; that was removed because
# (a) trycloudflare hostnames change every run, which breaks WebAuthn passkey
# enrollment across restarts (the RP ID changes), and (b) routes added by
# raw cloudflared aren't visible to `tunnels list`, so the staging script
# ended up with two different sources of truth for tunnel state. The whole
# project standardizes on `tunnels` for any cloudflared interaction.
#
# Config (~/.katulong/config.json):
#   stage.tunnel   Pin the named tunnel (skips auto-detect)
#   stage.domain   Override hostname → <name>.<stage.domain> instead of
#                  <name>.<tunnel>. Useful when the tunnel name and the
#                  public domain differ.
#
# State layout:
#   /tmp/katulong-stage/<name>/
#     ├── data/         KATULONG_DATA_DIR for the staging server
#     ├── server.log    server stdout+stderr
#     └── meta.env      key=value record consumed by stop/list
#
# Why a rewrite of the original katulong-stage script:
#   - The original used `cloudflared tunnel --url` exclusively, producing
#     ephemeral https://*.trycloudflare.com URLs that change on every run.
#     That's painful for passkey enrollment from a phone, because the
#     hostname (and therefore the WebAuthn RP ID) changes — every restart
#     forces re-pairing. Stable named tunnels via the `tunnels` CLI solve this.
#   - The original hand-crafted auth state JSON files (user.json,
#     setup-tokens/<id>.json) and re-implemented the scrypt hashing inline.
#     This duplicated the auth logic and would silently break if the
#     storage format changed. Using `katulong token create` against the
#     staging server's own API delegates to the canonical implementation.
#   - The original couldn't run multiple staging instances side-by-side
#     because tmux state wasn't isolated — any `tmux kill-server` call
#     would also kill the prod tmux. KATULONG_TMUX_SOCKET=stage-<name>
#     gives each staging its own socket so cleanup is surgical.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
STAGE_BASE="/tmp/katulong-stage"

# Resolve REPO_ROOT: explicit env var wins. Otherwise, if the caller's cwd is
# inside a git worktree that shares the same .git common dir as the main
# checkout (the script's own parent dir), use that worktree's root. This lets
# `katulong-stage start` work zero-argument from any worktree — the name
# defaults from the worktree's branch, server.js and node_modules resolve to
# the worktree's copies, and staging serves whatever version is checked out
# there. Falls back to the main checkout when run from outside any worktree.
resolve_repo_root() {
  if [[ -n "${REPO_ROOT:-}" ]]; then
    echo "$REPO_ROOT"
    return 0
  fi
  local main_root main_common cwd_top cwd_common
  main_root="$(cd "$SCRIPT_DIR/.." && pwd)"
  # Anchor every git call to an explicit -C <dir> so relative paths emitted
  # by --git-common-dir (".git" in a main checkout, "../.git" from a subdir,
  # absolute paths in linked worktrees) all resolve against the same base
  # the subsequent `cd` normalization uses. Without anchoring, running from
  # a main-checkout subdir emits "../.git" relative to the original cwd, but
  # the normalization `cd "$cwd_top" && cd <path>` resolves it against the
  # worktree toplevel — the two don't align and the cd lands nowhere,
  # silently disabling worktree detection.
  main_common="$(git -C "$main_root" rev-parse --git-common-dir 2>/dev/null)" || { echo "$main_root"; return 0; }
  main_common="$(cd "$main_root" && cd "$main_common" && pwd 2>/dev/null)" || { echo "$main_root"; return 0; }
  cwd_top="$(git rev-parse --show-toplevel 2>/dev/null)" || { echo "$main_root"; return 0; }
  cwd_common="$(git -C "$cwd_top" rev-parse --git-common-dir 2>/dev/null)" || { echo "$main_root"; return 0; }
  cwd_common="$(cd "$cwd_top" && cd "$cwd_common" && pwd 2>/dev/null)" || { echo "$main_root"; return 0; }
  if [[ "$main_common" == "$cwd_common" ]]; then
    echo "$cwd_top"
  else
    echo "$main_root"
  fi
}
REPO_ROOT="$(resolve_repo_root)"

# User-level config lives in the prod katulong's data dir, NOT in the per-staging
# dir we're about to create. Honor KATULONG_DATA_DIR if the user has overridden
# their personal data dir; otherwise default to ~/.katulong.
USER_DATA_DIR="${KATULONG_DATA_DIR:-$HOME/.katulong}"
USER_CONFIG="$USER_DATA_DIR/config.json"

is_alive() { kill -0 "$1" 2>/dev/null; }

# Read a dotted key (e.g. "stage.tunnel") from the user's config.json.
# Echoes the value on success, returns 1 if missing, unparseable, or
# present-but-not-a-string. We deliberately reject booleans/numbers so a typo
# like `"stage": { "tunnel": false }` fails loudly instead of stringifying to
# "false" and being passed to `tunnels route add`.
read_config_key() {
  local key="$1"
  [[ -f "$USER_CONFIG" ]] || return 1
  KATULONG_STAGE_CONFIG_PATH="$USER_CONFIG" KATULONG_STAGE_CONFIG_KEY="$key" node -e "
    const fs = require('fs');
    try {
      const c = JSON.parse(fs.readFileSync(process.env.KATULONG_STAGE_CONFIG_PATH, 'utf8'));
      const parts = process.env.KATULONG_STAGE_CONFIG_KEY.split('.');
      let v = c;
      for (const p of parts) {
        if (v == null || typeof v !== 'object') process.exit(1);
        v = v[p];
      }
      if (typeof v !== 'string' || v.length === 0) process.exit(1);
      process.stdout.write(v);
    } catch (e) { process.exit(1); }
  " 2>/dev/null
}

# Slugify a freeform name into something safe for hostnames, dirs, and tmux sockets.
slugify() {
  printf "%s" "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cs 'a-z0-9' '-' \
    | sed 's/^-//;s/-$//'
}

# Default staging name = the current git branch (slugified), or "stage" if detached.
default_name() {
  local b
  b="$(git -C "$REPO_ROOT" symbolic-ref --short HEAD 2>/dev/null || true)"
  [[ -z "$b" || "$b" == "HEAD" ]] && b="stage"
  slugify "$b"
}

# Ask Node for a free TCP port at or above $1.
#
# `process.stdout.write(String(p))` and not `console.log(p)` —
# when FORCE_COLOR is set (Playwright sets it for colorized
# test output, and that env propagates into our execSync
# invocations of this script), Node's `console.log(<number>)`
# wraps the value in ANSI yellow escape codes. Bash command
# substitution then captures `[33m3050[39m` instead of
# `3050`, which silently contaminates downstream KATULONG_*
# env vars and crashes the Rust server with "invalid port
# number". `process.stdout.write` of a string is plain.
find_free_port() {
  local from="${1:-3050}"
  node -e "
    const net = require('net');
    function tryPort(p) {
      return new Promise(resolve => {
        const s = net.createServer();
        s.listen(p, '127.0.0.1', () => { s.close(() => resolve(p)); });
        s.on('error', () => resolve(tryPort(p + 1)));
      });
    }
    tryPort($from).then(p => process.stdout.write(String(p)));
  "
}

# Pick a tunnel to attach staging routes to. Assumes the `tunnels` CLI is
# already installed — callers must enforce that precondition before invoking
# this function. (cmd_start does this with an upfront `command -v tunnels`
# check, so that it can print a richer install-instructions error message
# than this function is in a position to produce.)
#
# Resolution order:
#   1. `stage.tunnel` from $USER_CONFIG (if set, takes precedence — no auto-detect)
#   2. `tunnels list --json` — picks the first tunnel whose name looks like a
#      domain (contains a dot), otherwise just the first one.
#
# Echoes the tunnel name on success, returns 1 if nothing usable was found.
# Auto-detect is intentionally a fallback rather than the primary path so that
# users with multiple tunnels can pin staging to a specific one without ambiguity.
resolve_tunnel() {
  local configured
  configured="$(read_config_key 'stage.tunnel' || true)"
  if [[ -n "$configured" ]]; then
    printf "%s" "$configured"
    return 0
  fi
  local out
  out="$(tunnels list --json 2>/dev/null)" || return 1
  [[ -n "$out" ]] || return 1
  printf "%s" "$out" | node -e "
    let s='';
    process.stdin.on('data', d => s += d);
    process.stdin.on('end', () => {
      try {
        const list = JSON.parse(s);
        if (!Array.isArray(list) || list.length === 0) process.exit(1);
        const dotted = list.find(t => typeof t.name === 'string' && t.name.includes('.'));
        const t = dotted || list[0];
        if (!t || !t.name) process.exit(1);
        process.stdout.write(t.name);
      } catch (e) { process.exit(1); }
    });
  "
}

# Resolve the public hostname for a staging instance.
# Resolution order:
#   1. `stage.domain` from $USER_CONFIG → "<name>.<stage.domain>"
#   2. Default → "<name>.<tunnel>"
# This lets users separate "which tunnel to attach to" from "which domain to
# expose under" — e.g. tunnel `my-cf-tunnel` serving `*.example.com`.
resolve_host() {
  local name="$1"
  local tunnel="$2"
  local domain
  domain="$(read_config_key 'stage.domain' || true)"
  if [[ -n "$domain" ]]; then
    printf "%s.%s" "$name" "$domain"
  else
    printf "%s.%s" "$name" "$tunnel"
  fi
}

# Wait until the staging server is responding on $1, or fail.
# Each backend has its own canonical liveness probe:
#   - Node: `/login` (always served, public)
#   - Rust: `/health` (always served, public; Rust has no SPA
#     so /login isn't a route)
wait_for_server() {
  local port="$1"
  local pid="$2"
  local log="$3"
  local probe="$4"
  local i
  for i in $(seq 1 20); do
    if curl -fs -o /dev/null "http://127.0.0.1:${port}${probe}"; then
      return 0
    fi
    if ! is_alive "$pid"; then
      echo "ERROR: server died during startup. Tail of log:" >&2
      tail -30 "$log" >&2 || true
      return 1
    fi
    sleep 1
  done
  echo "ERROR: server not responding after 20s. Tail of log:" >&2
  tail -30 "$log" >&2 || true
  return 1
}

# Mint a setup token by calling the staging server's own CLI. The CLI uses
# KATULONG_DATA_DIR/server.json to find the live server, so pointing the env
# var at the staging data dir routes the token-create API call to the right
# instance. We pass `--json` and parse the structured output via Node rather
# than scraping the human format — that way the script keeps working if the
# `Token: <hex>` line ever changes wording, indentation, or color.
mint_setup_token() {
  local data_dir="$1"
  local name="$2"
  KATULONG_DATA_DIR="$data_dir" \
    node "$REPO_ROOT/bin/katulong" token create "$name" --json 2>/dev/null \
    | node -e "
      let s='';
      process.stdin.on('data', d => s += d);
      process.stdin.on('end', () => {
        try {
          const d = JSON.parse(s);
          if (typeof d.token === 'string' && d.token.length > 0) {
            process.stdout.write(d.token);
          } else {
            process.exit(1);
          }
        } catch (e) { process.exit(1); }
      });
    "
}

# Persist meta to $1/meta.env using key=value pairs (shell-quoted).
# Returns non-zero on any I/O failure so callers can clean up rather than
# silently leak a running server with no record of how to stop it.
write_meta() {
  local file="$1"
  shift
  : > "$file" || return 1
  while [[ $# -gt 0 ]]; do
    printf '%s=%q\n' "$1" "$2" >> "$file" || return 1
    shift 2
  done
}

# ---------------------------------------------------------------------------
# list
# ---------------------------------------------------------------------------
cmd_list() {
  if [[ ! -d "$STAGE_BASE" ]]; then
    echo "(no staging instances)"
    return 0
  fi
  local found=0
  local dir
  for dir in "$STAGE_BASE"/*/; do
    [[ -d "$dir" ]] || continue
    [[ -f "${dir}meta.env" ]] || continue
    local name="" port="" pid="" tunnel="" url=""
    # shellcheck disable=SC1090
    source "${dir}meta.env"
    if is_alive "${pid:-0}"; then
      printf "  %-22s pid=%-6s port=%-5s tunnel=%-20s url=%s\n" \
        "${name}" "${pid}" "${port}" "${tunnel:-?}" "${url:-?}"
      found=1
    fi
  done
  if [[ $found -eq 0 ]]; then
    echo "(no staging instances)"
  fi
  return 0
}

# ---------------------------------------------------------------------------
# stop
# ---------------------------------------------------------------------------
# Kill any process listening on a given TCP port. Used as a fallback when the
# PID in meta.env is stale (server was restarted, PID recycled, etc.). Without
# this, `stop` would kill the wrong process (or nothing) and the actual server
# would keep running as an orphan after `rm -rf` removes its tracking file.
kill_port_listener() {
  local port="$1"
  [[ -n "$port" ]] || return 0
  local pids
  pids="$(lsof -ti "TCP:${port}" -sTCP:LISTEN 2>/dev/null || true)"
  [[ -n "$pids" ]] || return 0
  for p in $pids; do
    kill "$p" 2>/dev/null || true
  done
  sleep 1
  for p in $pids; do
    is_alive "$p" && kill -9 "$p" 2>/dev/null || true
  done
}

stop_one() {
  local target="$1"
  local dir="$STAGE_BASE/$target"

  # If there's no meta.env, try to reap an orphan: kill any server whose
  # KATULONG_DATA_DIR points at this staging dir, kill the tmux socket,
  # and remove the directory. This handles the case where the start script
  # was interrupted between `nohup node server.js` and `write_meta`.
  if [[ -d "$dir" && ! -f "$dir/meta.env" ]]; then
    local orphan_pids
    orphan_pids="$(pgrep -f "KATULONG_DATA_DIR=$dir/data" 2>/dev/null || true)"
    for p in $orphan_pids; do
      kill "$p" 2>/dev/null || true
    done
    tmux -L "stage-$target" kill-server 2>/dev/null || true
    rm -rf "$dir"
    if [[ -n "$orphan_pids" ]]; then
      echo "Reaped orphan staging: $target"
    fi
    return 0
  fi

  if [[ ! -d "$dir" || ! -f "$dir/meta.env" ]]; then
    echo "No staging instance: $target" >&2
    return 1
  fi

  local name="" port="" pid="" tmux_socket="" tunnel="" host="" url="" data_dir="" log_file=""
  # shellcheck disable=SC1090
  source "$dir/meta.env"

  if [[ -n "${pid:-}" ]] && is_alive "$pid"; then
    kill "$pid" 2>/dev/null || true
    sleep 1
    is_alive "$pid" && kill -9 "$pid" 2>/dev/null || true
  fi

  # Fallback: also kill whatever is actually listening on the recorded port.
  # Catches the case where the server was restarted (new PID) but meta.env
  # still has the old PID.
  kill_port_listener "${port:-}"

  if [[ -n "${tmux_socket:-}" ]]; then
    tmux -L "$tmux_socket" kill-server 2>/dev/null || true
  fi

  if [[ -n "${host:-}" && -n "${tunnel:-}" ]] && command -v tunnels >/dev/null 2>&1; then
    tunnels route rm "$host" --tunnel "$tunnel" >/dev/null 2>&1 || true
  fi

  rm -rf "$dir"
  echo "Stopped staging: $target"
}

cmd_stop() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    [[ -d "$STAGE_BASE" ]] || { echo "(no staging instances)"; return 0; }
    local found=0
    local dir
    for dir in "$STAGE_BASE"/*/; do
      [[ -d "$dir" ]] || continue
      stop_one "$(basename "$dir")" && found=1
    done
    [[ $found -eq 0 ]] && echo "(no staging instances)"
    return 0
  fi
  stop_one "$(slugify "$target")"
}

# ---------------------------------------------------------------------------
# start
# ---------------------------------------------------------------------------

# Cleanup helper for cmd_start failure paths. Reaps a partially-started
# instance: kills the server pid if set and removes the staging dir. Used in
# every error branch so the cleanup logic stays in one place rather than
# being duplicated four times.
cleanup_start() {
  local server_pid="$1"
  local dir="$2"
  [[ -n "$server_pid" ]] && kill "$server_pid" 2>/dev/null || true
  rm -rf "$dir"
}

cmd_start() {
  local raw_name="${1:-}"
  local name
  name="$(slugify "${raw_name:-$(default_name)}")"
  [[ -n "$name" ]] || { echo "ERROR: empty name" >&2; return 1; }

  local dir="$STAGE_BASE/$name"

  # Idempotency: if a meta.env already exists and the pid is alive, just print it.
  # Source in a subshell so the meta.env's variables don't leak into and
  # accidentally shadow this function's local variables.
  if [[ -f "$dir/meta.env" ]]; then
    local existing
    existing="$(
      # shellcheck disable=SC1090
      source "$dir/meta.env"
      printf '%s\n%s\n%s\n' "${pid:-}" "${url:-}" "${port:-}"
    )"
    local existing_pid existing_url existing_port
    existing_pid="$(printf '%s' "$existing" | sed -n '1p')"
    existing_url="$(printf '%s' "$existing" | sed -n '2p')"
    existing_port="$(printf '%s' "$existing" | sed -n '3p')"
    if [[ -n "$existing_pid" ]] && is_alive "$existing_pid"; then
      echo "Already running: $name"
      printf "  URL: %s\n" "${existing_url:-?}"
      printf "  Port: %s (pid %s)\n" "${existing_port}" "${existing_pid}"
      return 0
    fi
    rm -rf "$dir"
  fi

  # Backend selection. Default is the Node implementation
  # (server.js); set KATULONG_STAGE_BACKEND=rust to launch the
  # Rust crate (target/release/katulong-server) instead. The
  # Rust path is a backend-only smoke harness — it has no SPA
  # served yet (the Leptos crate is a stub), so "poking around"
  # via browser shows nothing. Use it to verify the Rust binary
  # responds on /health, accepts WebSocket upgrades, and
  # handles auth/setup-token APIs.
  local backend="${KATULONG_STAGE_BACKEND:-node}"
  case "$backend" in
    node|rust) ;;
    *)
      echo "ERROR: KATULONG_STAGE_BACKEND must be 'node' or 'rust' (got: $backend)" >&2
      return 1
      ;;
  esac

  if [[ "$backend" == "node" && ! -f "$REPO_ROOT/server.js" ]]; then
    echo "ERROR: server.js not found in $REPO_ROOT" >&2
    return 1
  fi
  if [[ "$backend" == "rust" && ! -d "$REPO_ROOT/crates/server" ]]; then
    echo "ERROR: Rust backend requested but $REPO_ROOT/crates/server not present" >&2
    return 1
  fi

  # /tmp is world-traversable on macOS — lock the staging dirs to the owner
  # so nobody else on the box can (a) read meta.env (which contains the
  # running pid + port) or sniff data/auth-state.json, or (b) plant a hostile
  # meta.env under a directory name we'll later iterate over in `list`/`stop`
  # and then `source`. Locking the per-run dir alone is not enough because
  # STAGE_BASE itself is the directory we glob over — if STAGE_BASE is
  # world-writable, another local user can create /tmp/katulong-stage/evil/
  # meta.env containing arbitrary shell commands and get code execution the
  # next time we run `list` or `stop`.
  #
  # If STAGE_BASE already exists and is owned by a different user (squatting
  # attempt or leftover from a different account) the chmod will fail, and
  # we fail loud rather than continue with an unsafe base dir.
  mkdir -p "$STAGE_BASE"
  if ! chmod 700 "$STAGE_BASE" 2>/dev/null; then
    echo "ERROR: cannot lock $STAGE_BASE to owner-only (not owned by current user?)." >&2
    echo "       Remove or re-own it, or move it out of the way, then retry." >&2
    return 1
  fi
  mkdir -p "$dir/data"
  chmod 700 "$dir" "$dir/data"
  local data_dir="$dir/data"
  local log_file="$dir/server.log"
  local tmux_socket="stage-$name"
  local port; port="$(find_free_port 3050)"

  echo "Starting staging '$name' on port $port..."

  # Clear any stale socket file for this stage name before tmux tries to
  # bind. tmux does not unlink the socket on `kill-server`, so a prior
  # `stop` of the same name leaves `/tmp/tmux-$UID/stage-<name>` behind,
  # and a new tmux server starting on that path can get confused by the
  # dead inode. This is the "pre-clear my own slot" side of the cleanup
  # contract; the sibling piece is the boot-time sweep in
  # test/helpers/setup-env.js for the PID-scoped test sockets.
  rm -f "${TMUX_TMPDIR:-/tmp}/tmux-$(id -u)/$tmux_socket"

  if [[ "$backend" == "node" ]]; then
    if [[ ! -d "$REPO_ROOT/node_modules" ]]; then
      echo "  installing deps..."
      (cd "$REPO_ROOT" && npm install --silent)
    fi
    PORT="$port" \
    KATULONG_DATA_DIR="$data_dir" \
    KATULONG_TMUX_SOCKET="$tmux_socket" \
      nohup node "$REPO_ROOT/server.js" > "$log_file" 2>&1 &
  else
    # Rust backend. Build the release binary if missing or out
    # of date relative to source. cargo's incremental build is
    # cheap when nothing has changed.
    local rust_bin="$REPO_ROOT/target/release/katulong-server"
    echo "  building rust binary (release)..."
    if ! (cd "$REPO_ROOT" && cargo build --release -p katulong-server 2>&1 | tail -3); then
      echo "ERROR: cargo build failed" >&2
      return 1
    fi
    if [[ ! -x "$rust_bin" ]]; then
      echo "ERROR: $rust_bin not found after build" >&2
      return 1
    fi

    # Build the Leptos frontend bundle so the static-asset
    # fallback in the server has something to serve. Skipping
    # this (or running it after server start) leaves the URL
    # showing the trunk-build-not-yet-run warning in the
    # server log and a 404 in the browser. Trunk is required;
    # if the operator hasn't installed it, fail fast — the
    # staging script can't paper over a missing toolchain.
    if ! command -v trunk >/dev/null 2>&1; then
      echo "ERROR: 'trunk' CLI is not installed (required for Rust staging)." >&2
      echo "       Install: cargo install trunk" >&2
      return 1
    fi
    echo "  building leptos bundle (trunk release)..."
    if ! (cd "$REPO_ROOT/crates/web" && trunk build --release 2>&1 | tail -3); then
      echo "ERROR: trunk build failed" >&2
      return 1
    fi
    local web_dist="$REPO_ROOT/crates/web/dist"
    if [[ ! -f "$web_dist/index.html" ]]; then
      echo "ERROR: $web_dist/index.html not found after trunk build" >&2
      return 1
    fi

    # KATULONG_ORIGIN must match the URL the browser actually
    # uses, or webauthn-rs's clientDataJSON.origin check
    # rejects every assertion. The default in main.rs is
    # `http://localhost:3000`, which only happens to match
    # when the operator hand-launches with PORT=3000. For
    # staging on a dynamic port, the local URL is
    # http://localhost:$port — set it here so passkey
    # ceremonies actually verify.
    PORT="$port" \
    KATULONG_DATA_DIR="$data_dir" \
    KATULONG_TMUX_SOCKET="$tmux_socket" \
    KATULONG_WEB_DIST="$web_dist" \
    KATULONG_ORIGIN="http://localhost:$port" \
      nohup "$rust_bin" > "$log_file" 2>&1 &
  fi
  local server_pid=$!

  # Trap signals so an interrupted start doesn't orphan the server process.
  # nohup makes the server immune to SIGHUP, so without this trap a Ctrl-C
  # or Claude session timeout between server start and write_meta leaves a
  # running server with no meta.env — invisible to list/stop.
  # shellcheck disable=SC2064
  trap "cleanup_start '$server_pid' '$dir'; exit 130" INT TERM HUP

  local probe_path
  if [[ "$backend" == "rust" ]]; then
    probe_path="/health"
  else
    probe_path="/login"
  fi
  if ! wait_for_server "$port" "$server_pid" "$log_file" "$probe_path"; then
    trap - INT TERM HUP
    cleanup_start "$server_pid" "$dir"
    return 1
  fi

  local token
  if [[ "$backend" == "rust" ]]; then
    # The Rust server's token-mint API requires auth (CSRF +
    # `Authenticated`), and there's no equivalent CLI yet that
    # writes a token directly to AuthStore for bootstrap. Skip
    # the mint and tell the caller this is a backend-only
    # smoke instance. /health and /api/me are reachable; the
    # full UI flow needs the Leptos frontend.
    token=""
    echo "  ⚠ rust backend: setup-token mint skipped (CLI not implemented)"
  else
    token="$(mint_setup_token "$data_dir" "$name" || true)"
    if [[ -z "$token" ]]; then
      echo "ERROR: failed to mint setup token (server up but token CLI returned nothing)" >&2
      trap - INT TERM HUP
      cleanup_start "$server_pid" "$dir"
      return 1
    fi
  fi

  # ---- Tunnel wiring ----
  # The `tunnels` CLI is the single supported path. If it isn't installed
  # or no usable named tunnel can be resolved, fail loud rather than silently
  # falling back to a different mechanism. See the header comment for the
  # reasoning behind dropping the ephemeral cloudflared path.
  if ! command -v tunnels >/dev/null 2>&1; then
    echo "ERROR: 'tunnels' CLI is not installed." >&2
    echo "       Install it (brew tap dorky-robot/tap && brew install tunnels)" >&2
    echo "       and register at least one named tunnel via 'tunnels add'." >&2
    trap - INT TERM HUP
    cleanup_start "$server_pid" "$dir"
    return 1
  fi

  local tunnel host url
  tunnel="$(resolve_tunnel || true)"
  if [[ -z "$tunnel" ]]; then
    echo "ERROR: no named tunnel available." >&2
    echo "       Register one with 'tunnels add <name> --token <token>'," >&2
    echo "       or pin one in ~/.katulong/config.json via:" >&2
    echo '         { "stage": { "tunnel": "<tunnel-name>" } }' >&2
    trap - INT TERM HUP
    cleanup_start "$server_pid" "$dir"
    return 1
  fi
  host="$(resolve_host "$name" "$tunnel")"

  if ! tunnels route add "$host" "$port" --tunnel "$tunnel" >/dev/null 2>&1; then
    echo "ERROR: 'tunnels route add $host $port --tunnel $tunnel' failed." >&2
    echo "       Check 'tunnels list' and 'tunnels logs $tunnel'." >&2
    tunnels route rm "$host" --tunnel "$tunnel" >/dev/null 2>&1 || true
    trap - INT TERM HUP
    cleanup_start "$server_pid" "$dir"
    return 1
  fi
  url="https://$host"

  # If meta.env can't be persisted we MUST tear the instance down — otherwise
  # `stop` has no record of pid/port/tunnel and the server runs forever as an
  # orphan, holding a port + DNS route that nothing knows how to release.
  if ! write_meta "$dir/meta.env" \
    name "$name" \
    port "$port" \
    pid "$server_pid" \
    tmux_socket "$tmux_socket" \
    tunnel "$tunnel" \
    host "$host" \
    url "$url" \
    data_dir "$data_dir" \
    log_file "$log_file"; then
    echo "ERROR: failed to write meta.env — refusing to leave a running server with no stop record" >&2
    tunnels route rm "$host" --tunnel "$tunnel" >/dev/null 2>&1 || true
    trap - INT TERM HUP
    cleanup_start "$server_pid" "$dir"
    return 1
  fi

  # meta.env is written — server is now trackable by stop/list. Clear the
  # signal trap so normal script exit doesn't kill the server we just started.
  trap - INT TERM HUP

  if [[ "$backend" == "rust" ]]; then
    cat <<EOF

Staging '$name' is live (BACKEND: rust):

  URL:         $url
  Port:        $port (pid $server_pid)
  Tmux Socket: $tmux_socket
  Tunnel:      $tunnel
  Data Dir:    $data_dir
  Log:         tail -f $log_file

Verify the Rust binary is what's responding:
  curl $url/health                    # → "ok"
  ps -p $server_pid -o command=       # should show .../target/release/katulong-server

The Leptos hello-world shell is served at /; trunk-built
WASM hydrates on load. Browse the URL or run the e2e smoke:
  KATULONG_BASE_URL=$url npx playwright test --config=playwright.rust.config.js

Stop:
  $(basename "$0") stop $name

EOF
  else
    cat <<EOF

Staging '$name' is live:

  URL:         $url
  Pair URL:    $url/login?setup_token=$token
  Setup Token: $token
  Port:        $port (pid $server_pid)
  Tmux Socket: $tmux_socket
  Tunnel:      $tunnel
  Data Dir:    $data_dir
  Log:         tail -f $log_file

Stop:
  $(basename "$0") stop $name

EOF
  fi
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
usage() {
  cat <<EOF
katulong-stage — stage isolated Katulong instances behind a Cloudflare tunnel

Usage:
  $(basename "$0") start [name]    Start staging (default name = current branch)
  $(basename "$0") stop  [name]    Tear down staging (default = all instances)
  $(basename "$0") list            Show running staging instances

Requirements:
  The 'tunnels' CLI must be installed and at least one named tunnel must be
  registered. There is no fallback path. To install:
    brew tap dorky-robot/tap && brew install tunnels
    tunnels add <name> --token <cloudflare-tunnel-token>

Config (~/.katulong/config.json or \$KATULONG_DATA_DIR/config.json):
  stage.tunnel   Pin the named tunnel to use (skips auto-detect)
  stage.domain   Override the hostname domain — host becomes <name>.<stage.domain>
                 instead of <name>.<tunnel>. Useful when the tunnel name and the
                 public domain differ (e.g. tunnel "my-cf-tunnel" → "example.com").

  Example:
    {
      "stage": {
        "tunnel": "my-tunnel-name",
        "domain": "example.com"
      }
    }
EOF
}

main() {
  local sub="${1:-}"
  case "$sub" in
    start) shift; cmd_start "${1:-}" ;;
    stop)  shift; cmd_stop  "${1:-}" ;;
    list|ls) cmd_list ;;
    -h|--help|help|"") usage ;;
    *) echo "Unknown command: $sub" >&2; usage >&2; exit 2 ;;
  esac
}

main "$@"
