#!/usr/bin/env node
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";
import { readFileSync } from "node:fs";

const __dirname = dirname(fileURLToPath(import.meta.url));
const ROOT = join(__dirname, "..");

// Read version from package.json
const pkg = JSON.parse(readFileSync(join(ROOT, "package.json"), "utf-8"));
const VERSION = pkg.version;

const COMMANDS = {
  start: "Start the Katulong server",
  stop: "Stop the Katulong server",
  restart: "Restart the Katulong server",
  status: "Check if Katulong is running",
  logs: "Stream server logs",
  open: "Open Katulong in your browser",
  attach: "Open a terminal tab in the browser (creates session if needed)",
  notify: "Send a native notification to connected browsers",
  pub: "Publish a message to a topic",
  sub: "Subscribe to a topic (streams to stdout)",
  topics: "List active pub/sub topics",
  info: "Show system information and configuration",
  update: "Update Katulong to the latest version",
  token: "Manage setup tokens (create, list, revoke)",
  credential: "Manage passkey credentials (list, revoke)",
  session: "Manage terminal sessions (list, create, kill, rename)",
  notes: "Read per-session notepad content (read, list)",
  service: "Manage macOS LaunchAgent (install, uninstall, restart, status)",
};

function showHelp() {
  console.log(`
katulong v${VERSION} - Your terminal, everywhere

USAGE:
  katulong <command> [options]

COMMANDS:
${Object.entries(COMMANDS)
  .map(([cmd, desc]) => `  ${cmd.padEnd(12)} ${desc}`)
  .join("\n")}

OPTIONS:
  --help, -h    Show this help message
  --version, -v Show version number

EXAMPLES:
  katulong start              Start the server
  katulong restart            Restart the server
  katulong stop               Stop the server
  katulong status             Check if running
  katulong logs               Stream server logs
  katulong open               Open in browser
  katulong update             Update to latest version
  katulong update --check     Check if update is available
  katulong update --no-restart Update code but skip restart
  katulong token create "My Phone"  Create a setup token
  katulong token list         List setup tokens
  katulong credential list    List registered passkeys
  katulong session list       List active PTY sessions
  katulong session kill dev   Kill a PTY session
  katulong attach myapp       Open "myapp" tab in browser (creates if needed)
  katulong notify "done"      Send notification to connected browsers
  katulong notes read         Read notes for current session
  katulong notes todos        List unchecked todos
  katulong notes check "fix"  Check off a matching todo
  katulong service install    Auto-start on login (macOS)
  katulong service restart    Restart after brew upgrade

For more information, visit: https://github.com/dorky-robot/katulong
`);
}

function showVersion() {
  console.log(`katulong v${VERSION}`);
}

async function main() {
  const args = process.argv.slice(2);
  const command = args[0];

  // Handle flags
  if (!command || command === "--help" || command === "-h") {
    showHelp();
    process.exit(0);
  }

  if (command === "--version" || command === "-v") {
    showVersion();
    process.exit(0);
  }

  // Hidden internal commands (not shown in help)
  const INTERNAL_COMMANDS = ["_finish-upgrade"];

  // Dispatch to command handler
  if (!COMMANDS[command] && !INTERNAL_COMMANDS.includes(command)) {
    console.error(`Error: Unknown command '${command}'`);
    console.error(`Run 'katulong --help' for usage information`);
    process.exit(1);
  }

  try {
    const handler = await import(`../lib/cli/commands/${command}.js`);
    await handler.default(args.slice(1));
  } catch (err) {
    if (err.code === "ERR_MODULE_NOT_FOUND") {
      console.error(`Error: Command '${command}' not yet implemented`);
    } else {
      console.error(`Error: ${err.message}`);
      if (process.env.DEBUG) {
        console.error(err.stack);
      }
    }
    process.exit(1);
  }
}

main();
