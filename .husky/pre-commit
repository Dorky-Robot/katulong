#!/usr/bin/env bash
# .husky/pre-commit — fast, deterministic checks before every commit
#
# Hook chain:
#   1. Secrets scan   (gitleaks — BLOCKING)
#   2. Auth bypass scan (grep — BLOCKING)
#   3. Spell check    (typos — BLOCKING)
#   4. Targeted tests (mapped from staged files — BLOCKING)
#
# Activate once per clone:
#   git config core.hooksPath .husky

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

warn() { echo "  WARN  $*" >&2; }
fail() { echo "  ERROR $*" >&2; exit 1; }
step() { echo ""; echo "==> $*"; }

# Get staged files early — skip if nothing staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-commit checks"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── 1. Secrets scan (BLOCKING) ────────────────────────────────────────────────
step "[1/4] Secrets scan"
SCRIPT_DIR="$(cd "$(dirname "$0")/../scripts" && pwd)"
. "$SCRIPT_DIR/secrets-scan.sh"
if ! scan_secrets "pre-commit"; then
  fail "Secrets detected — commit blocked. Remove secrets before committing."
fi
echo "      OK  No secrets detected"

# ── 2. Auth bypass scan (BLOCKING) ────────────────────────────────────────────
# Katulong provides direct terminal access to the host. Any mechanism to disable
# auth is equivalent to giving root shell access to anyone on the internet.
# This check blocks any attempt to reintroduce auth bypass patterns.
step "[2/4] Auth bypass scan"
AUTH_BYPASS_PATTERNS='NO_AUTH|SKIP_AUTH|DISABLE_AUTH|AUTH_DISABLED|BYPASS_AUTH|AUTH_BYPASS'
# Only scan source files, not test files or docs (tests may reference removed patterns)
AUTH_BYPASS_HITS=$(git diff --cached -U0 --diff-filter=ACMR -- 'lib/*.js' 'server.js' 'public/*.js' 'public/lib/*.js' \
  | grep -E '^\+' | grep -v '^\+\+\+' \
  | grep -iE "$AUTH_BYPASS_PATTERNS" || true)
if [ -n "$AUTH_BYPASS_HITS" ]; then
  echo ""
  echo "  BLOCKED: Auth bypass pattern detected in staged changes:"
  echo "$AUTH_BYPASS_HITS"
  echo ""
  echo "  Katulong MUST always require authentication. There is no valid"
  echo "  reason to add a way to disable auth — this app provides direct"
  echo "  terminal access to the host machine."
  echo ""
  fail "Auth bypass pattern detected — commit blocked."
fi
echo "      OK  No auth bypass patterns"

# ── 3. Spell check (BLOCKING) ────────────────────────────────────────────────
step "[3/4] Spell check (typos)"
if command -v typos >/dev/null 2>&1; then
  if ! typos --format brief; then
    fail "Spelling errors found — commit blocked. Fix typos or add to _typos.toml to ignore."
  fi
  echo "      OK  No spelling errors"
else
  warn "typos not installed — skipping spell check."
  warn "Install: cargo install typos-cli  OR  brew install typos-cli"
fi

# ── 4. Targeted tests (BLOCKING) ─────────────────────────────────────────────
step "[4/4] Targeted tests (mapped from staged files)"

map_to_test() {
  case "$1" in
    lib/http-util.js) echo "test/http-util.test.js" ;;
    lib/auth.js)      echo "test/auth.test.js" ;;
    lib/log.js)       echo "test/log.test.js" ;;
    server.js)        echo "test/http-util.test.js" ;;
    lib/session-manager.js) echo "test/sessions-crud.integration.js" ;;
    test/*.test.js|test/*.integration.js) echo "$1" ;;
  esac
}

TO_RUN=""

while IFS= read -r file; do
  [ -z "$file" ] && continue
  test_file=$(map_to_test "$file")
  if [ -n "$test_file" ]; then
    case " $TO_RUN " in
      *" $test_file "*) ;;
      *) TO_RUN="$TO_RUN $test_file" ;;
    esac
  fi
done <<STAGED_EOF
$STAGED_FILES
STAGED_EOF

TO_RUN=$(echo "$TO_RUN" | sed 's/^ //')

if [ -n "$TO_RUN" ]; then
  echo "      Running: $TO_RUN"
  if ! node --experimental-test-module-mocks --test --test-concurrency=0 $TO_RUN; then
    fail "Tests failed — commit blocked. Fix tests before committing."
  fi
  echo "      OK  All targeted tests passed"
else
  echo "      OK  No test mappings for staged files — skipping"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  All pre-commit checks passed — proceeding with commit."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
