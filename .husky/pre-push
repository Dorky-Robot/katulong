#!/usr/bin/env bash
# .husky/pre-push — full validation before push
#
# Hook chain:
#   1. Review agents  (background — BLOCKING at end)
#   2. Test suite     (unit + integration + smoke E2E — BLOCKING)
#   3. Secrets scan   (BLOCKING)
#   4. Wait for agents (BLOCKING)
#
# Activate once per clone:
#   git config core.hooksPath .husky

set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

warn() { echo "  WARN  $*" >&2; }
fail() { echo "  ERROR $*" >&2; exit 1; }
step() { echo ""; echo "==> $*"; }

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-push checks"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# --- Save stdin before anything else consumes it ---
PUSH_INPUT=$(cat)

# --- Determine what commits are being pushed ---
DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
ZERO="0000000000000000000000000000000000000000"
PUSH_DIFF=""
CHANGED_FILES=""

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_ref" ] && continue

  if [ "$local_sha" = "$ZERO" ]; then
    continue
  fi

  if [ "$remote_sha" = "$ZERO" ]; then
    MERGE_BASE=$(git merge-base "origin/$DEFAULT_BRANCH" "$local_sha" 2>/dev/null || echo "")
    if [ -n "$MERGE_BASE" ]; then
      PUSH_DIFF="${PUSH_DIFF}$(git diff "$MERGE_BASE".."$local_sha")"
      CHANGED_FILES="${CHANGED_FILES}$(git diff --name-only "$MERGE_BASE".."$local_sha")"
    fi
  else
    PUSH_DIFF="${PUSH_DIFF}$(git diff "$remote_sha".."$local_sha")"
    CHANGED_FILES="${CHANGED_FILES}$(git diff --name-only "$remote_sha".."$local_sha")"
  fi
done <<PUSH_INPUT_HEREDOC
$PUSH_INPUT
PUSH_INPUT_HEREDOC

SCRIPT_DIR="$(cd "$(dirname "$0")/../scripts" && pwd)"

# ── 1. Start review agents in background ─────────────────────────────────────
step "[1/4] Review agents (background)"
REVIEW_PID=""
if [ -z "$PUSH_DIFF" ]; then
  echo "      No diff to review — skipping agents (tests still run)"
else
  TMPDIR_REVIEW=$(mktemp -d)
  trap 'rm -rf "$TMPDIR_REVIEW"' EXIT
  printf '%s\n' "$PUSH_DIFF" > "$TMPDIR_REVIEW/diff.txt"
  printf '%s\n' "$CHANGED_FILES" > "$TMPDIR_REVIEW/files.txt"

  "$SCRIPT_DIR/review.sh" --hook pre-push \
    --diff-file "$TMPDIR_REVIEW/diff.txt" \
    --files-file "$TMPDIR_REVIEW/files.txt" &
  REVIEW_PID=$!
  echo "      Started review agents (PID $REVIEW_PID)"
fi

# ── 2. Test suite (BLOCKING) ─────────────────────────────────────────────────
step "[2/4] Test suite (unit + integration + smoke E2E)"

# Check if Playwright E2E tests can run
E2E_AVAILABLE=0
if node -e "const { chromium } = require('@playwright/test'); chromium.launch().then(b => b.close()).catch(() => process.exit(1))" >/dev/null 2>&1; then
  E2E_AVAILABLE=1
fi

NCPUS=$(sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || echo 4)
HALF_CPUS=$(( NCPUS / 2 ))
[ "$HALF_CPUS" -lt 1 ] && HALF_CPUS=1

# Check if mock.module is available (requires Node >= 22.3 with experimental flag).
# Exclude test files that use mock.module when it's not supported to prevent
# false failures on systems with older Node versions.
MOCK_MODULE_OK=0
if node --experimental-test-module-mocks -e \
  "const t = require('node:test'); if (typeof t.mock?.module !== 'function') process.exit(1)" \
  >/dev/null 2>&1; then
  MOCK_MODULE_OK=1
fi

TEST_FILES=""
for f in test/*.test.js test/*.integration.js; do
  if [ "$MOCK_MODULE_OK" -eq 0 ] && grep -q 'mock\.module' "$f" 2>/dev/null; then
    continue
  fi
  TEST_FILES="$TEST_FILES $f"
done

if [ "$MOCK_MODULE_OK" -eq 0 ]; then
  warn "mock.module unavailable — excluding tests that require it"
fi

# Use a temp data dir for tests if the default (~/.katulong) is not writable
# (common in containers/CI where the dir is owned by root).
TEST_DATA_DIR=""
if touch "$HOME/.katulong/.pre-push-test" 2>/dev/null; then
  rm -f "$HOME/.katulong/.pre-push-test"
else
  TEST_DATA_DIR=$(mktemp -d)
  export KATULONG_DATA_DIR="$TEST_DATA_DIR"
fi

UNIT_LOG=$(mktemp)
UNIT_RC=0; E2E_RC=0

if [ "$E2E_AVAILABLE" -eq 1 ]; then
  echo "      Running unit/integration + smoke E2E in parallel ($NCPUS cores)"
  E2E_LOG=$(mktemp)

  node --import ./test/helpers/setup-env.js --experimental-test-module-mocks --test --test-concurrency="$HALF_CPUS" $TEST_FILES > "$UNIT_LOG" 2>&1 &
  UNIT_PID=$!

  npm run test:e2e:smoke > "$E2E_LOG" 2>&1 &
  E2E_PID=$!

  wait "$UNIT_PID" || UNIT_RC=$?
  wait "$E2E_PID" || E2E_RC=$?

  if [ "$E2E_RC" -ne 0 ]; then
    echo "      FAIL  Smoke E2E failed (exit $E2E_RC):"
    cat "$E2E_LOG"
  else
    echo "      OK  Smoke E2E passed"
  fi
  rm -f "$E2E_LOG"
else
  warn "Playwright browser unavailable — skipping E2E tests"
  node --import ./test/helpers/setup-env.js --experimental-test-module-mocks --test --test-concurrency="$HALF_CPUS" $TEST_FILES > "$UNIT_LOG" 2>&1 &
  UNIT_PID=$!
  wait "$UNIT_PID" || UNIT_RC=$?
fi

if [ "$UNIT_RC" -ne 0 ]; then
  echo "      FAIL  Unit/integration tests failed (exit $UNIT_RC):"
  cat "$UNIT_LOG"
else
  echo "      OK  Unit/integration tests passed"
fi
rm -f "$UNIT_LOG"
[ -n "$TEST_DATA_DIR" ] && rm -rf "$TEST_DATA_DIR"

if [ "$UNIT_RC" -ne 0 ] || [ "$E2E_RC" -ne 0 ]; then
  [ -n "$REVIEW_PID" ] && { kill "$REVIEW_PID" 2>/dev/null; wait "$REVIEW_PID" 2>/dev/null; }
  fail "Tests failed — push blocked. Fix tests before pushing."
fi

# ── 3. Secrets scan (BLOCKING) ───────────────────────────────────────────────
step "[3/4] Secrets scan"
. "$SCRIPT_DIR/secrets-scan.sh"
if ! scan_secrets "pre-push"; then
  [ -n "$REVIEW_PID" ] && { kill "$REVIEW_PID" 2>/dev/null; wait "$REVIEW_PID" 2>/dev/null; }
  fail "Secrets detected — push blocked. Remove secrets before pushing."
fi
echo "      OK  No secrets detected"

# ── 4. Wait for review agents (BLOCKING) ─────────────────────────────────────
step "[4/4] Review agents (waiting for results)"
if [ -n "$REVIEW_PID" ]; then
  echo "      Waiting for review agents to finish..."
  wait "$REVIEW_PID"
  REVIEW_RC=$?
  if [ "$REVIEW_RC" -ne 0 ]; then
    fail "Review agents found issues — push blocked. Fix issues before pushing."
  fi
  echo "      OK  Review agents passed"
else
  echo "      OK  Skipped (no diff)"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  All pre-push checks passed — proceeding with push."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
